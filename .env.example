# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env al repositorio

# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db"

# JWT
JWT_KEY="clave-secreta-minimo-32-caracteres"

# AWS S3 (almacenamiento de documentos y reportes)
NOMBRE_BUCKET="nombre-del-bucket"
REGION_BUCKET="us-east-2"
AWS_CLAVE_ACCESO="AKIAXXXXXXXXXXXXXXXX"
AWS_CLAVE_ACCESO_ESPECIAL="clave-secreta-aws"

# WhatsApp Business API (Meta)
WHATSAPP_TOKEN=token-de-acceso-meta
WHATSAPP_PHONE_ID=id-del-numero-de-telefono
WHATSAPP_VERSION=v19.0
WHATSAPP_VERIFY_TOKEN=token-verificacion-webhook
